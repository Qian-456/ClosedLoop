DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Logging (optional; defaults are used when omitted)
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION=30 days
LOG_ROTATION=10 MB
LOG_ELK_ENABLED=false
LOG_ELK_LEVEL=DEBUG
LOG_ELK_JSON_PATH=logs/elk.jsonl
FILTER_LOG_DETAILED_DEBUG=true
LOG_PLANNER_STATS=false
PLANNER_LOG_DETAILED_DEBUG=false

# LangSmith / LangChain tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ClosedLoop

# Mock DB (optional; defaults are used when omitted)
# Edit catalog files then re-generate mock_db.
MOCK_DB_REPO_DIR=mock_db
MOCK_DB_CATALOG_DIR=local_mock_db/catalog
MOCK_DB_RW_DIR=local_mock_db/runtime
