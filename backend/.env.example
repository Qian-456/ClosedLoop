DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Services API
# 如果主后端运行在宿主机本地（如 python backend/src/cli_main.py 或 python backend/src/main.py），
# 请使用 PLAN_SUB_NETWORK_MODE=local，并将 PLAN_SUB_API_URL 配置为 localhost / 127.0.0.1。
# 如果主后端运行在 Docker Compose 网络内，
# 请使用 PLAN_SUB_NETWORK_MODE=docker，并将 PLAN_SUB_API_URL 配置为 http://plan_sub_backend:8001/plan。
MILVUS_URI=http://localhost:19530
PLAN_SUB_API_URL=http://localhost:8001/plan
SEARCH_SUB_API_URL=http://127.0.0.1:8002/search
PLAN_SUB_NETWORK_MODE=local

# Logging (optional; defaults are used when omitted)
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION=30 days
LOG_ROTATION=10 MB
LOG_ELK_ENABLED=false
LOG_ELK_LEVEL=DEBUG
LOG_ELK_JSON_PATH=logs/elk/elk_{time:YYYY-MM-DD}.jsonl
FILTER_LOG_DETAILED_DEBUG=true
LOG_PLANNER_STATS=false
PLANNER_LOG_DETAILED_DEBUG=false

# LangSmith / LangChain tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ClosedLoop

# Mock DB (optional; defaults are used when omitted)
FORCE_REBUILD_VECTORS=false
